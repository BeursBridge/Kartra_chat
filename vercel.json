{
  "buildCommand": "npm --prefix managed-chatkit/frontend install && npm --prefix managed-chatkit/frontend run build",
  "outputDirectory": "managed-chatkit/frontend/dist",
  "functions": {
    "api/create-session.py": {
      "runtime": "now-python@3.12", // <-- Gecorrigeerd naar de exacte syntax die Vercel verwacht
      "includeFiles": "requirements.txt"
    }
  },
  "routes": [
    {
      "src": "/api/create-session",
      "dest": "/api/create-session.py",
      "methods": ["POST"]
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
